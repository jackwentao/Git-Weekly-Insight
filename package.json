{
  "name": "weekly-report",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "weekly-report": "./bin/weekly-report.js"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --import tsx --test src/lib/ai/deepseek.test.ts src/lib/report/parseAiReport.test.ts src/lib/report/publicOutput.test.ts",
    "test:e2e": "node --import tsx --test src/e2e/generateWeeklyReport.e2e.test.ts",
    "test:e2e:api": "node --import tsx --test src/e2e/apiWeeklyReport.e2e.test.ts",
    "perf:check": "node --import tsx ./src/bin/perf-check.ts",
    "report": "node --import tsx ./src/bin/cli.ts",
    "report:generate": "npm run report -- generate",
    "report:dry": "npm run report -- dry-run",
    "report:check": "npm run report -- check-config"
  },
  "dependencies": {
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
